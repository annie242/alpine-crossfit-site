<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <h4>Alpine CrossFit</h4>
        <p>{{ site.address.street }}<br>{{ site.address.city }}, {{ site.address.region }} {{ site.address.postalCode }}<br><a href="tel:{{ site.phone }}">{{ site.phoneDisplay }}</a></p>
        <p class="text-muted" style="font-size:0.85rem;">Founded {{ site.founded }} · Under current ownership since {{ site.ownershipSince }}</p>
      </div>
      <div>
        <h4>Train</h4>
        <ul>
        {%- for item in site.footerColumns.train %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
        {%- endfor %}
        </ul>
      </div>
      <div>
        <h4>Info</h4>
        <ul>
        {%- for item in site.footerColumns.info %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
        {%- endfor %}
        </ul>
      </div>
      <div>
        <h4>Areas</h4>
        <ul>
        {%- for item in site.footerColumns.areas %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
        {%- endfor %}
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <div>© 2026 Alpine CrossFit. All rights reserved.</div>
      <div><a href="{{ site.instagram }}">Instagram</a></div>
    </div>
  </div>
</footer>
