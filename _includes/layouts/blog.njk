---
layout: layouts/base.njk
---
{# Blog index. Lists every post in collections.blog, newest first.
   Frontmatter expected: title, description, eyebrow, heading, dek. #}
<section class="hero">
  <div class="container container-narrow">
    {% if eyebrow %}<div class="hero-eyebrow">{{ eyebrow }}</div>{% endif %}
    <h1>{{ heading | safe }}</h1>
    {% if dek %}<p class="hero-dek">{{ dek | safe }}</p>{% endif %}
  </div>
</section>

<section class="section">
  <div class="container container-narrow">
    {% if collections.blog | length %}
    {%- for post in collections.blog %}
    <article style="padding:var(--space-8) 0;border-bottom:1px solid rgba(0,0,0,0.1);">
      <p class="text-muted" style="text-transform:uppercase;letter-spacing:0.1em;font-weight:700;font-size:0.85rem;margin-bottom:var(--space-2);">{{ post.date | readableDate }}</p>
      <h2 style="margin-bottom:var(--space-3);"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
      {% if post.data.description %}<p>{{ post.data.description }}</p>{% endif %}
      <a href="{{ post.url }}" style="color:var(--color-alpine-green);font-weight:700;">Read the post →</a>
    </article>
    {%- endfor %}
    {% else %}
    <p class="text-muted">No posts yet — check back soon.</p>
    {% endif %}
  </div>
</section>
