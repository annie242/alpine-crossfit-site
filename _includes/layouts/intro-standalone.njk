<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
<meta name="robots" content="noindex,nofollow">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&family=Barlow+Condensed:ital,wght@1,700;1,800&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #71b035;
    --black: #000000;
    --surface: #121212;
    --text: #ffffff;
    --muted: #a8a8a3;
    --border: #2a2a28;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--black);
    color: var(--text);
    font-family: "Archivo", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 17px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  .container { max-width: 820px; margin: 0 auto; padding: 0 1.5rem; }
  h1 {
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 700;
    font-style: italic;
    text-transform: uppercase;
    font-size: clamp(2.5rem, 7vw, 4rem);
    line-height: 1;
    margin: 0 0 1.5rem 0;
    letter-spacing: -0.005em;
  }
  h1 .accent { color: var(--green); }
  h2 {
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 700;
    font-style: italic;
    text-transform: uppercase;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1;
    margin: 0 0 1rem 0;
  }
  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--green);
    display: block;
    margin-bottom: 0.75rem;
  }
  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--green);
    margin-bottom: 1.5rem;
  }
  .dek { font-size: 1.15rem; color: var(--muted); margin-bottom: 2rem; line-height: 1.55; }
  .hero { padding: 4rem 0 3rem; border-bottom: 2px solid var(--green); }
  .section { padding: 3rem 0; border-bottom: 1px solid var(--border); }
  .section-dark { background: var(--surface); }
  .section-green {
    background: var(--green);
    color: var(--black);
    text-align: center;
  }
  .section-green h2 { color: var(--black); }
  .section-green .dek { color: rgba(0,0,0,0.8); }
  .form-wrap {
    background: #fff;
    border-radius: 6px;
    overflow: hidden;
    margin-top: 1.5rem;
  }
  .form-wrap iframe {
    width: 100%;
    min-height: 700px;
    border: none;
    display: block;
  }
  a {
    color: var(--green);
    text-decoration: none;
    font-weight: 500;
  }
  a:hover { color: #8dc850; }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.1rem 2.25rem;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 2px;
    border: 2px solid transparent;
    transition: all 200ms ease;
    min-height: 48px;
  }
  .btn-dark { background: var(--black); color: #fff; }
  .btn-dark:hover { background: #222; color: #fff; }
  ol { line-height: 1.8; color: var(--muted); }
  ol strong { color: var(--text); }
  .muted { color: var(--muted); font-size: 0.9rem; }
  .mt-6 { margin-top: 1.5rem; }
  .footer {
    background: var(--surface);
    padding: 2rem 0;
    color: var(--muted);
    font-size: 0.85rem;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
</style>
</head>
<body>

<main>

<section class="hero">
  <div class="container">
    <div class="hero-eyebrow">{{ eyebrow }}</div>
    <h1>{{ heading | safe }}</h1>
    <p class="dek">{{ dek | safe }}</p>
  </div>
</section>

{{ content | safe }}

</main>

<footer class="footer">
  <div class="container">
    {{ footerText | safe }}
  </div>
</footer>

<!-- GoHighLevel embed script: auto-resizes the booking iframe to fit its content -->
<script src="https://link.gymntx.com/js/form_embed.js" type="text/javascript"></script>

</body>
</html>
