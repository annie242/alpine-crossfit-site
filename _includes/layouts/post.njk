---
layout: layouts/base.njk
---
{# Single blog post. Frontmatter expected (see content/blog/blog.json for
   the shared layout/permalink defaults):
   - title (post headline + browser title) — required
   - description (meta description + listing blurb) — required
   - date (publish date, YYYY-MM-DD) — required
   - The markdown body becomes the post content.
#}

{# JSON-LD emitted from the template body so {{ title }} and page.date
   are evaluated at render time. Google reads JSON-LD anywhere in the
   HTML — it doesn't have to live in <head>. #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | jsonStringify | safe }},
  "description": {{ description | jsonStringify | safe }},
  "datePublished": "{{ page.date | isoDate }}",
  "dateModified": "{{ page.date | isoDate }}",
  "author": {
    "@type": "Organization",
    "@id": "{{ site.url }}/#organization",
    "name": "{{ site.name }}"
  },
  "publisher": { "@id": "{{ site.url }}/#organization" },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}{{ page.url }}"
  },
  "inLanguage": "en-US",
  "isPartOf": { "@id": "{{ site.url }}/blog/#blog" }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "{{ site.url }}/blog/" },
    { "@type": "ListItem", "position": 3, "name": {{ title | jsonStringify | safe }}, "item": "{{ site.url }}{{ page.url }}" }
  ]
}
</script>

<section class="hero">
  <div class="container container-narrow">
    <p class="hero-eyebrow"><a href="/blog/" style="color:var(--color-alpine-green);">← All posts</a></p>
    <p class="text-muted" style="text-transform:uppercase;letter-spacing:0.1em;font-weight:700;font-size:0.9rem;margin-bottom:var(--space-3);">{{ page.date | readableDate }}</p>
    <h1>{{ title }}</h1>
    {% if description %}<p class="hero-dek">{{ description }}</p>{% endif %}
  </div>
</section>

<section class="section">
  <div class="container container-narrow">
    {{ content | safe }}
  </div>
</section>

<section class="section section-green">
  <div class="container text-center">
    <h2>Ready to train with us?</h2>
    <div class="hero-cta" style="justify-content:center;">
      <a class="btn btn-lg" style="background:#000;color:#fff;" href="/free-intro/">Book my free No Sweat Intro</a>
    </div>
  </div>
</section>
