---
layout: layouts/base.njk
schemaTypes: ["organization", "healthclub", "faq"]
loadImagesScript: true
speakable: true
---
{# Homepage layout. The homepage is unique enough that nearly every section
   has its own structured frontmatter — Lisa edits text, the layout stays
   locked. Frontmatter expected:
     - hero: { eyebrow, heading, dek, ctas, image{ src, alt, slot }, trustItems[] }
     - affiliations: [ { image, label } ]
     - whoSection: { eyebrow, heading, intro[], cards[{ heading, body }] }
     - howToStart: { eyebrow, heading, steps[{ heading, body }], ctaLabel, ctaHref }
     - services: { eyebrow, heading, items[{ heading, body, link }] }
     - pricing: { eyebrow, heading, intro, tiers[{ heading, price, unit, features[], ctaLabel, ctaHref, featured }], moreLink }
     - reviews: { eyebrow, heading, testimonials[{ stars, quote, attribution }], stats[{ value, label }] }
     - scheduleSection: { eyebrow, heading, blocks[{ heading, lines[] }], moreLink, locationCard{ heading, dl[{label, value}], ctaLabel, ctaHref } }
     - faqs: [ { question, answer } ]
     - faqMoreLink: string (URL)
     - finalCta: { heading, body, ctas[{ label, href, inlineStyle }] }
#}

<!-- HERO -->
<section class="hero">
  <div class="container hero-with-image">
    <div class="hero-text">
      {% if hero.eyebrow %}<div class="hero-eyebrow">{{ hero.eyebrow }}</div>{% endif %}
      <h1>{{ hero.heading | safe }}</h1>
      {% if hero.dek %}<p class="hero-dek">{{ hero.dek | safe }}</p>{% endif %}
      {% if hero.ctas %}
      <div class="hero-cta">
        {%- for cta in hero.ctas %}
        <a class="btn {{ cta.style or 'btn-primary btn-lg' }}" href="{{ cta.href }}">{{ cta.label }}</a>
        {%- endfor %}
      </div>
      {% endif %}
      {% if hero.trustItems %}
      <div class="trust-strip">
        {%- for t in hero.trustItems %}
          {%- if t.type == 'stars' %}<span class="stars">★★★★★</span>{% endif -%}
          {%- if t.text %}<span>{{ t.text | safe }}</span>{% endif -%}
          {%- if not loop.last %}<span class="sep">·</span>{% endif -%}
        {%- endfor %}
      </div>
      {% endif %}
    </div>
    <div class="hero-media">
      <img src="{{ hero.image.src }}" alt="{{ hero.image.alt }}" class="hero-image" loading="eager" fetchpriority="high"{% if hero.image.slot %} data-image-slot="{{ hero.image.slot }}"{% endif %}>
    </div>
  </div>
</section>

{% if affiliations %}
<!-- AFFILIATIONS -->
<section class="affiliations">
  <div class="container">
    <div class="affiliations-row">
      {%- for a in affiliations %}
      <div class="affiliation-item">
        <img src="{{ a.image }}" alt="{{ a.alt }}" class="affiliation-badge">
        <div class="affiliation-label">{{ a.label | safe }}</div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
{% endif %}

{% if whoSection %}
<!-- WHO -->
<section class="section">
  <div class="container">
    <span class="eyebrow">{{ whoSection.eyebrow }}</span>
    <h2 class="section-heading">{{ whoSection.heading }}</h2>
    <div class="split">
      <div>
        {%- for p in whoSection.intro %}
        <p>{{ p | safe }}</p>
        {%- endfor %}
      </div>
      <div class="grid grid-3" style="gap: var(--space-4);">
      {%- for c in whoSection.cards %}
        <div class="card">
          <h3>{{ c.heading }}</h3>
          <p>{{ c.body | safe }}</p>
        </div>
      {%- endfor %}
      </div>
    </div>
  </div>
</section>
{% endif %}

{% if howToStart %}
<!-- HOW TO START -->
<section class="section section-dark">
  <div class="container">
    <span class="eyebrow">{{ howToStart.eyebrow }}</span>
    <h2 class="section-heading">{{ howToStart.heading }}</h2>
    <div class="grid grid-3">
    {%- for s in howToStart.steps %}
      <div class="card">
        <h3>{{ s.heading }}</h3>
        <p>{{ s.body | safe }}</p>
      </div>
    {%- endfor %}
    </div>
    {% if howToStart.ctaLabel %}
    <div class="mt-8 text-center">
      <a class="btn btn-primary btn-lg" href="{{ howToStart.ctaHref }}">{{ howToStart.ctaLabel }}</a>
    </div>
    {% endif %}
  </div>
</section>
{% endif %}

{% if services %}
<!-- SERVICES -->
<section class="section">
  <div class="container">
    <span class="eyebrow">{{ services.eyebrow }}</span>
    <h2 class="section-heading">{{ services.heading }}</h2>
    <div class="grid grid-3">
    {%- for item in services.items %}
      <div class="card">
        <h3>{{ item.heading }}</h3>
        <p>{{ item.body | safe }}</p>
        {% if item.link %}<a href="{{ item.link }}">Learn more →</a>{% endif %}
      </div>
    {%- endfor %}
    </div>
  </div>
</section>
{% endif %}

{% if pricing %}
<!-- PRICING -->
<section class="section section-dark">
  <div class="container">
    <span class="eyebrow">{{ pricing.eyebrow }}</span>
    <h2 class="section-heading">{{ pricing.heading }}</h2>
    {% if pricing.intro %}<p class="hero-dek">{{ pricing.intro | safe }}</p>{% endif %}
    <div class="grid grid-3 mt-8">
    {%- for t in pricing.tiers %}
      <div class="card{% if t.featured %} card-featured{% endif %}">
        <h3>{{ t.heading }}</h3>
        <div class="price">{{ t.price }}<span class="price-unit">{{ t.unit }}</span></div>
        <ul class="feature-list">
        {%- for f in t.features %}
          <li{% if f.muted %} class="muted"{% endif %}>{{ f.text or f }}</li>
        {%- endfor %}
        </ul>
        <a class="btn {% if t.featured %}btn-primary{% else %}btn-secondary{% endif %}" href="{{ t.ctaHref }}">{{ t.ctaLabel }}</a>
      </div>
    {%- endfor %}
    </div>
    {% if pricing.moreLink %}
    <div class="mt-8 text-center">
      <a href="{{ pricing.moreLink.href }}">{{ pricing.moreLink.label }}</a>
    </div>
    {% endif %}
  </div>
</section>
{% endif %}

{% if reviews %}
<!-- REVIEWS -->
<section class="section">
  <div class="container">
    <span class="eyebrow">{{ reviews.eyebrow }}</span>
    <h2 class="section-heading">{{ reviews.heading }}</h2>
    <div class="grid grid-3">
    {%- for t in reviews.testimonials %}
      <div class="testimonial">
        <div class="testimonial-stars">★★★★★</div>
        <p class="testimonial-quote">"{{ t.quote | safe }}"</p>
        <div class="testimonial-attribution">— {{ t.attribution | safe }}</div>
      </div>
    {%- endfor %}
    </div>
    {% if reviews.stats %}
    <div class="stat-row mt-8">
    {%- for s in reviews.stats %}
      <div class="stat">
        <div class="stat-value">{{ s.value }}</div>
        <div class="stat-label">{{ s.label }}</div>
      </div>
    {%- endfor %}
    </div>
    {% endif %}
  </div>
</section>
{% endif %}

{% if scheduleSection %}
<!-- SCHEDULE -->
<section class="section section-dark" id="schedule">
  <div class="container">
    <span class="eyebrow">{{ scheduleSection.eyebrow }}</span>
    <h2 class="section-heading">{{ scheduleSection.heading }}</h2>
    <div class="split">
      <div>
        {%- for b in scheduleSection.blocks %}
        <h3{% if not loop.first %} class="mt-8"{% endif %}>{{ b.heading }}</h3>
        {%- for line in b.lines %}
        <p>{{ line | safe }}</p>
        {%- endfor %}
        {%- endfor %}
        {% if scheduleSection.note %}<p class="text-muted">{{ scheduleSection.note | safe }}</p>{% endif %}
        {% if scheduleSection.moreLink %}
        <div class="mt-6">
          <a class="btn btn-secondary" href="{{ scheduleSection.moreLink.href }}">{{ scheduleSection.moreLink.label }}</a>
        </div>
        {% endif %}
      </div>
      {% if scheduleSection.locationCard %}
      <div class="location-card">
        <h3>{{ scheduleSection.locationCard.heading }}</h3>
        <dl>
        {%- for row in scheduleSection.locationCard.rows %}
          <dt>{{ row.label }}</dt><dd>{{ row.value | safe }}</dd>
        {%- endfor %}
        </dl>
        <div class="mt-6">
          <a class="btn btn-primary" href="{{ scheduleSection.locationCard.ctaHref }}">{{ scheduleSection.locationCard.ctaLabel }}</a>
        </div>
      </div>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{% if faqs %}
<!-- FAQ -->
<section class="section">
  <div class="container container-narrow">
    <span class="eyebrow">Common questions</span>
    <h2 class="section-heading">Common questions.</h2>
    {%- for f in faqs %}
    <details class="faq-item">
      <summary>{{ f.question }}</summary>
      <div class="faq-answer">{{ f.answer | safe }}</div>
    </details>
    {%- endfor %}
    {% if faqMoreLink %}
    <div class="mt-8">
      <a href="{{ faqMoreLink }}">See all FAQs →</a>
    </div>
    {% endif %}
  </div>
</section>
{% endif %}

{% if finalCta %}
<!-- FINAL CTA -->
<section class="section section-green">
  <div class="container text-center">
    <h2>{{ finalCta.heading }}</h2>
    {% if finalCta.body %}<p class="hero-dek" style="margin-left:auto;margin-right:auto;color:rgba(0,0,0,0.8);">{{ finalCta.body | safe }}</p>{% endif %}
    <div class="hero-cta" style="justify-content:center;">
      {%- for cta in finalCta.ctas %}
      <a class="btn btn-lg" style="{{ cta.inlineStyle or 'background:#000;color:#fff;' }}" href="{{ cta.href }}">{{ cta.label }}</a>
      {%- endfor %}
    </div>
  </div>
</section>
{% endif %}
